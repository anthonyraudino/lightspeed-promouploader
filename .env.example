# Lightspeed X-Series OAuth Configuration
# ==========================================
# 
# SETUP INSTRUCTIONS:
# 1. Register a developer account: https://developers.retail.lightspeed.app/register
# 2. Create an application: https://developers.retail.lightspeed.app/applications/add
# 3. Note your client_id and client_secret
# 4. Set your redirect_uri (e.g., http://localhost:3000/callback)
# 5. Fill in the OAuth credentials below
# 6. Run: node authenticate.js authorize
#

# OAuth Credentials (from Lightspeed Developer Portal)
LS_CLIENT_ID=your_client_id_here
LS_CLIENT_SECRET=your_client_secret_here
LS_REDIRECT_URI=http://localhost:3000/redirect

# Optional: Specify which API scopes your app needs
# See: https://x-series-api.lightspeedhq.com/docs/scopes
# Default: products:read sales:read customers:read
LS_SCOPES=products:read sales:read customers:read

# The following are AUTOMATICALLY SET by authenticate.js after OAuth flow
# Do NOT manually edit these - they are managed by the OAuth module:
# LS_ACCESS_TOKEN=
# LS_REFRESH_TOKEN=
# LS_TOKEN_EXPIRES_AT=
# LS_DOMAIN_PREFIX=

# OR: Use Personal Token (for Plus plan only)
# If you prefer, you can use a personal token instead of OAuth:
# LS_DOMAIN_PREFIX=your-store-prefix
# LS_ACCESS_TOKEN=your_personal_token
# See: https://x-series-api.lightspeedhq.com/docs/authorization#personal-tokens

# Promotion Uploader Configuration
# =================================

# The Lightspeed promotion ID to upload codes to
LS_PROMOTION_ID=your_promotion_id_here

# API version (optional, defaults to 2026-04)
# LS_API_VERSION=2026-04

# Custom field names for promo codes (optional)
# LS_PROMO_CODE_FIELD=code
# LS_PROMO_REDEMPTION_FIELD=max_redemptions

# Whether to include set_promo_code field (set to false if API rejects it)
# LS_INCLUDE_SET_PROMO_CODE=true
